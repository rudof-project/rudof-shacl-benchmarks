@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:acme a ex:Organization ;
  ex:name "ACME Corp" .

ex:alice a ex:Person ;
  ex:name "Alice Smith" ;
  ex:age 30 ;
  ex:email "alice@example.org" ;
  ex:worksAt ex:acme .

ex:bob a ex:Person ;
  ex:name "Bob Jones" ;
  ex:age 45 ;
  ex:email "bob@example.org" .
