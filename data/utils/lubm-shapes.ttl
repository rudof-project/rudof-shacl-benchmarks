@prefix :    <http://weso.es/shapes#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix ub:  <file:///data/univ-bench.owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Shapes for data generated by the LUBM UBA generator (edu.lehigh.swat.bench.uba).
# Constraints follow the structural invariants enforced by Generator.java:
# faculty teach 1-2 undergrad + 1-2 grad courses, undergrads take 2-4 courses,
# grads take 1-3 graduate courses, at most one full professor per department is
# the chair (ub:headOf), etc.

# ---------------------------------------------------------------------------
# Organisations
# ---------------------------------------------------------------------------

# Universities appear both as fully described instances (one per requested
# university) and as bare references from ub:{undergraduate,masters,doctoral}
# DegreeFrom and from ub:subOrganizationOf. Those references receive a
# rdf:type ub:University triple but no ub:name, so name is optional.
:University a sh:NodeShape ;
  sh:targetClass ub:University ;
  sh:nodeKind sh:IRI ;
  sh:property [
    sh:path ub:name ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] .

:Department a sh:NodeShape ;
  sh:targetClass ub:Department ;
  sh:nodeKind sh:IRI ;
  sh:property [
    sh:path ub:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path ub:subOrganizationOf ;
    sh:class ub:University ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

:ResearchGroup a sh:NodeShape ;
  sh:targetClass ub:ResearchGroup ;
  sh:nodeKind sh:IRI ;
  sh:property [
    sh:path ub:subOrganizationOf ;
    sh:class ub:Department ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

# ---------------------------------------------------------------------------
# Courses
# ---------------------------------------------------------------------------

:Course a sh:NodeShape ;
  sh:targetClass ub:Course ;
  sh:nodeKind sh:IRI ;
  sh:property [
    sh:path ub:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

:GraduateCourse a sh:NodeShape ;
  sh:targetClass ub:GraduateCourse ;
  sh:nodeKind sh:IRI ;
  sh:property [
    sh:path ub:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

# ---------------------------------------------------------------------------
# Faculty (abstract building blocks composed via sh:and below)
# ---------------------------------------------------------------------------

# Properties shared by every faculty member: name, taught courses, three
# alma maters, employing department, contact info.
:FacultyProperties a sh:NodeShape ;
  sh:property [
    sh:path ub:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path ub:teacherOf ;
    sh:nodeKind sh:IRI ;
    sh:minCount 2 ;
    sh:maxCount 4 ;
    sh:or (
      [ sh:class ub:Course ]
      [ sh:class ub:GraduateCourse ]
    ) ;
  ] ;
  sh:property [
    sh:path ub:undergraduateDegreeFrom ;
    sh:class ub:University ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path ub:mastersDegreeFrom ;
    sh:class ub:University ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path ub:doctoralDegreeFrom ;
    sh:class ub:University ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path ub:worksFor ;
    sh:class ub:Department ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path ub:emailAddress ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:pattern "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$" ;
  ] ;
  sh:property [
    sh:path ub:telephone ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

# Professors additionally declare a research interest.
:ProfessorProperties a sh:NodeShape ;
  sh:property [
    sh:path ub:researchInterest ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

:FullProfessor a sh:NodeShape ;
  sh:targetClass ub:FullProfessor ;
  sh:nodeKind sh:IRI ;
  sh:and ( :FacultyProperties :ProfessorProperties ) ;
  # Optional: only the department chair has ub:headOf.
  sh:property [
    sh:path ub:headOf ;
    sh:class ub:Department ;
    sh:maxCount 1 ;
  ] .

:AssociateProfessor a sh:NodeShape ;
  sh:targetClass ub:AssociateProfessor ;
  sh:nodeKind sh:IRI ;
  sh:and ( :FacultyProperties :ProfessorProperties ) .

:AssistantProfessor a sh:NodeShape ;
  sh:targetClass ub:AssistantProfessor ;
  sh:nodeKind sh:IRI ;
  sh:and ( :FacultyProperties :ProfessorProperties ) .

:Lecturer a sh:NodeShape ;
  sh:targetClass ub:Lecturer ;
  sh:nodeKind sh:IRI ;
  sh:and ( :FacultyProperties ) .

# ---------------------------------------------------------------------------
# Students
# ---------------------------------------------------------------------------

# Properties shared by every student: name, department, contact info, and an
# optional advisor (one of the three professor ranks).
:StudentProperties a sh:NodeShape ;
  sh:property [
    sh:path ub:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path ub:memberOf ;
    sh:class ub:Department ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path ub:emailAddress ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:pattern "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$" ;
  ] ;
  sh:property [
    sh:path ub:telephone ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path ub:advisor ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
    sh:or (
      [ sh:class ub:FullProfessor ]
      [ sh:class ub:AssociateProfessor ]
      [ sh:class ub:AssistantProfessor ]
    ) ;
  ] .

:UndergraduateStudent a sh:NodeShape ;
  sh:targetClass ub:UndergraduateStudent ;
  sh:nodeKind sh:IRI ;
  sh:and ( :StudentProperties ) ;
  sh:property [
    sh:path ub:takesCourse ;
    sh:class ub:Course ;
    sh:minCount 2 ;
    sh:maxCount 4 ;
  ] .

:GraduateStudent a sh:NodeShape ;
  sh:targetClass ub:GraduateStudent ;
  sh:nodeKind sh:IRI ;
  sh:and ( :StudentProperties ) ;
  sh:property [
    sh:path ub:takesCourse ;
    sh:class ub:GraduateCourse ;
    sh:minCount 1 ;
    sh:maxCount 3 ;
  ] ;
  sh:property [
    sh:path ub:undergraduateDegreeFrom ;
    sh:class ub:University ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

# TA / RA are additional types layered onto a GraduateStudent instance.
:TeachingAssistant a sh:NodeShape ;
  sh:targetClass ub:TeachingAssistant ;
  sh:nodeKind sh:IRI ;
  sh:property [
    sh:path ub:teachingAssistantOf ;
    sh:class ub:Course ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

:ResearchAssistant a sh:NodeShape ;
  sh:targetClass ub:ResearchAssistant ;
  sh:nodeKind sh:IRI .

# ---------------------------------------------------------------------------
# Publications
# ---------------------------------------------------------------------------

# Authors are always at least the originating faculty member, optionally
# extended with graduate students.
:Publication a sh:NodeShape ;
  sh:targetClass ub:Publication ;
  sh:nodeKind sh:IRI ;
  sh:property [
    sh:path ub:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path ub:publicationAuthor ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:or (
      [ sh:class ub:FullProfessor ]
      [ sh:class ub:AssociateProfessor ]
      [ sh:class ub:AssistantProfessor ]
      [ sh:class ub:Lecturer ]
      [ sh:class ub:GraduateStudent ]
    ) ;
  ] .
